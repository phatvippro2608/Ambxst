{
  "disks": [
    "/"
  ],
  "updateServiceEnabled": true,
  "display": {
    "mode": "extend"
  },
  "idle": {
    "general": {
      "lock_cmd": "ambxst lock",
      "before_sleep_cmd": "loginctl lock-session && ambxst screen off",
      "after_sleep_cmd": "ambxst screen on"
    },
    "screen_off_timeout_battery": 600,
    "screen_off_timeout_ac": 600,
    "suspend_timeout_battery": 600,
    "suspend_timeout_ac": 1800,
    "listeners": [
      {
        "onResume": "ambxst brightness -r",
        "onTimeout": "ambxst brightness 10 -s",
        "timeout": 150
      },
      {
        "onTimeout": "loginctl lock-session",
        "timeout": 300
      },
      {
        "onResume": "ambxst screen on",
        "onTimeout": "ambxst screen off",
        "timeout": 330
      },
      {
        "onTimeout": "ambxst suspend",
        "timeout": 1800
      }
    ]
  },
  "ocr": {
    "eng": true,
    "spa": true,
    "lat": false,
    "jpn": false,
    "chi_sim": false,
    "chi_tra": false,
    "kor": false
  },
  "pomodoro": {
    "workTime": 1500,
    "restTime": 300,
    "autoStart": true,
    "syncSpotify": true
  },
  "location": {
    "allowWeatherApp": true,
    "allowAiApp": true,
    "allowTimezoneApp": true
  }
}